# You can use either the root URL or the login URL.
# Both of these now work:
# LMS_BASE_URL=https://lms.sltc.ac.lk
# LMS_BASE_URL=https://lms.sltc.ac.lk/login/index.php
LMS_BASE_URL=https://lms.sltc.ac.lk/login/index.php

LMS_USERNAME=your_lms_username
LMS_PASSWORD=your_lms_password
MOODLE_CALENDAR_URL=your_moodle_calendar_export_url

TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

CF_ACCOUNT_ID=your_cloudflare_account_id
CF_KV_NAMESPACE_ID=your_cloudflare_kv_namespace_id
CF_API_TOKEN=your_cloudflare_api_token

# Optional filters. Leave both empty to watch all modules.
# Best option: use Moodle course IDs from course URLs like /course/view.php?id=123
WATCHED_COURSE_IDS=

# Use course codes or course name parts, comma-separated.
# Example: WATCHED_COURSE_NAMES=CCS3310,Software Engineering Methods,Database Systems
WATCHED_COURSE_NAMES=

# loose = keep calendar events that do not clearly show the module name/id, so you do not miss deadlines.
# strict = only keep calendar events that match WATCHED_COURSE_IDS or WATCHED_COURSE_NAMES.
CALENDAR_FILTER_MODE=loose

# false is safer because removed/hidden alerts can become noisy in messy Moodle systems.
NOTIFY_REMOVED_ITEMS=false
